# ==============================
# Drive2Facebook Automation - Environment Variables
# ==============================

# App
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Session / CSRF
COOKIE_SECRET=replace_with_a_long_random_secret

# Token Encryption (AES-256, must be 32 chars)
TOKEN_ENCRYPTION_KEY=replace_with_32_character_secret

# PostgreSQL
DATABASE_URL=postgres://d2f_user:d2f_password@localhost:5432/drive2facebook
PGHOST=localhost
PGPORT=5432
PGUSER=d2f_user
PGPASSWORD=d2f_password
PGDATABASE=drive2facebook

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth / Drive API
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Meta (Facebook) OAuth / Graph API
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/auth/facebook/callback
FACEBOOK_GRAPH_VERSION=v19.0

# Email (SMTP) for verification / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=noreply@drive2facebook.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Upload engine
TEMP_UPLOAD_DIR=./uploads
SCHEDULE_CHECK_CRON=* * * * *
MAX_RANDOM_DELAY_SECONDS=300

# AI Video Generation (Kie.ai)
KIE_API_KEY=
KIE_BASE_URL=https://api.kie.ai
KIE_VIDEO_MODEL=kling/v2-1-standard
VIDEOGEN_POLL_CRON=*/1 * * * *

# AI Content Pipeline (Google Gemini — script + voiceover, same free API key for both)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_TTS_VOICE=Kore
CONTENT_PIPELINE_CRON=* * * * *
CONTENT_CLIP_SECONDS=10
